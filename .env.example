# Identifiants Udemy Business
UDEMY_EMAIL=prenom.nom@example.com
UDEMY_PASSWORD=mot-de-passe

# Planning (heure locale) - supprimer pour tourner 24/7
SCHEDULE_START=22:00
SCHEDULE_END=04:00
TIMEZONE=Europe/Paris

# Dashboard de monitoring (login: admin / mot de passe ci-dessous)
MONITOR_PORT=3000
MONITOR_PASSWORD=change-moi

# Cours à enchaîner dans l'ordre (première vidéo de chaque cours)
COURSE_URL_1=https://xxx.udemy.com/course/nom-du-cours/learn/lecture/123456
COURSE_URL_2=https://xxx.udemy.com/course/autre-cours/learn/lecture/789012
